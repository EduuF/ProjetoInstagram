# =============================================================================
# .env de PRODUÇÃO — copie pra .env na EC2 e preencha.
#
# IMPORTANTE: apenas valores NÃO sensíveis vivem aqui. Segredos (JWT,
# ENCRYPTION, INSTAGRAM_APP_SECRET, DATABASE_URL) ficam no AWS Secrets Manager
# e são carregados automaticamente pelo loader em ``app/config.py`` quando
# ``AWS_SECRETS_NAME`` está definido.
# =============================================================================

# ---------------------------------------------------------------------------
# Ambiente
# ---------------------------------------------------------------------------
ENVIRONMENT=production
DB_AUTO_CREATE=false

# ---------------------------------------------------------------------------
# AWS Secrets Manager
# ---------------------------------------------------------------------------
# Nome (ou ARN) do segredo JSON que contém: DATABASE_URL, JWT_SECRET,
# ENCRYPTION_KEY, INSTAGRAM_APP_ID, INSTAGRAM_APP_SECRET, VERIFY_TOKEN.
AWS_SECRETS_NAME=replibo/prod
AWS_REGION=us-east-1

# ---------------------------------------------------------------------------
# Instagram Graph API (valores não sensíveis)
# ---------------------------------------------------------------------------
GRAPH_API_VERSION=v25.0
GRAPH_API_BASE_URL=https://graph.instagram.com

# ---------------------------------------------------------------------------
# Webhook
# ---------------------------------------------------------------------------
# Em produção SEMPRE true. Assina todo POST /webhook com o App Secret.
WEBHOOK_VERIFY_SIGNATURE=true

# ---------------------------------------------------------------------------
# Frontend / CORS / Cookies
# ---------------------------------------------------------------------------
FRONTEND_ORIGIN=https://app.replibo.com

# Cross-site entre app.* e api.* exige SameSite=None + Secure=true.
COOKIE_SECURE=true
COOKIE_SAMESITE=none

# Permite que o cookie seja enviado pra app.* E api.* do mesmo eTLD+1.
# NOTA: use o eTLD+1 (ex.: ``.seudominio.com.br``, com ponto na frente).
COOKIE_DOMAIN=.replibo.com

# Nome do cookie (pode ficar no default).
SESSION_COOKIE_NAME=access_token

# ---------------------------------------------------------------------------
# OAuth Instagram
# ---------------------------------------------------------------------------
OAUTH_REDIRECT_URI=https://api.replibo.com/auth/instagram/callback
OAUTH_SCOPES=instagram_business_basic,instagram_business_manage_comments,instagram_business_manage_messages
OAUTH_STATE_EXPIRES_MINUTES=10

# ---------------------------------------------------------------------------
# Token refresher
# ---------------------------------------------------------------------------
TOKEN_REFRESHER_INTERVAL_MINUTES=60
TOKEN_REFRESH_BEFORE_DAYS=10

# ---------------------------------------------------------------------------
# JWT (tempo de expiração — valor não sensível)
# ---------------------------------------------------------------------------
JWT_EXPIRES_MINUTES=1440
